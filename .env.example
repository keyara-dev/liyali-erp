# =============================================================================
# Liyali Gateway — Master Environment Variables Guide
# =============================================================================
#
# This file is the single reference for ALL environment variables used across
# every sub-project in this monorepo. Copy the relevant section into each
# folder and rename it ".env", then fill in real values.
#
#   backend/        → Go API server      → copy into backend/.env
#   frontend/       → Next.js user app   → copy into frontend/.env
#   admin-console/  → Next.js admin app  → copy into admin-console/.env
#
# None of the .env files are committed to git (.env* is in .gitignore).
# Only .env.example files are committed as documentation.
# =============================================================================


# =============================================================================
# BACKEND  (backend/.env)
# =============================================================================

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------

# Single connection string — preferred for all environments.
# PaaS platforms (Railway, Aiven, Supabase …) inject this automatically.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Fallback individual vars — used only when DATABASE_URL is not set.
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=change-me
# DB_NAME=liyali-dev-db
# DB_SSL_MODE=disable

# Skip DB connectivity check on startup (useful for slow / remote networks)
SKIP_DB_VALIDATION=false

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------

APP_PORT=8080

# "development" | "staging" | "production"
# In production: gates JWT fail-fast, forces DB SSL, sets GORM warn-level logs.
APP_ENV=development

# JWT secret — REQUIRED in prod (server exits if empty when APP_ENV=production).
# Use >= 32 random characters.
JWT_SECRET=change-me-to-a-32+-char-random-string

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------

# Comma-separated allowed origins. If unset, defaults to http://localhost:3000.
# In prod set this to your real frontend + admin URLs or requests will be rejected.
FRONTEND_URL=http://localhost:3000,http://localhost:3001

# ----------------------------------------------------------------------------
# Email — Resend (https://resend.com)
# ----------------------------------------------------------------------------

# Leave blank to run in stub / log-only mode (emails printed to app log).
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# In development use Resend's shared test domain: onboarding@resend.dev
# In production use a verified domain address: noreply@yourdomain.com
EMAIL_FROM=onboarding@resend.dev


# =============================================================================
# FRONTEND  (frontend/.env)
# =============================================================================

# ----------------------------------------------------------------------------
# Backend connection
# ----------------------------------------------------------------------------

# URL the Next.js server actions use to reach the Go backend.
# Read by src/app/_actions/api-config.ts. If unset, falls back to
# http://localhost:8080 — in prod that means every API call fails. MUST be set.
BASE_URL=http://localhost:8080

# ----------------------------------------------------------------------------
# Auth
# ----------------------------------------------------------------------------

# Session secret (>= 32 chars). src/lib/auth.ts throws at boot if unset.
# Either name is accepted; set one (or both to the same value).
AUTH_SECRET=change-me-to-a-32+-char-random-string
# NEXTAUTH_SECRET=change-me-to-a-32+-char-random-string

# ----------------------------------------------------------------------------
# Public app URLs (build-time + runtime)
# ----------------------------------------------------------------------------

NEXT_PUBLIC_APP_URL=https://liyali.com
# Consumed at build time only (not by the API client — that uses BASE_URL).
NEXT_PUBLIC_API_URL=https://api.liyali.com

# ----------------------------------------------------------------------------
# ImageKit — file / image uploads (https://imagekit.io)
# ----------------------------------------------------------------------------

NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
NEXT_PUBLIC_IMAGEKIT_AUTH_ENDPOINT=/api/imagekit-auth

# ----------------------------------------------------------------------------
# SEO & verification
# ----------------------------------------------------------------------------

GOOGLE_SITE_VERIFICATION=your_google_verification_code
YANDEX_VERIFICATION=your_yandex_verification_code
YAHOO_VERIFICATION=your_yahoo_verification_code

# ----------------------------------------------------------------------------
# Analytics
# ----------------------------------------------------------------------------

NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ----------------------------------------------------------------------------
# Social & contact
# ----------------------------------------------------------------------------

NEXT_PUBLIC_TWITTER_HANDLE=@liyalisuite
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/liyali-suite
NEXT_PUBLIC_SUPPORT_EMAIL=support@liyali.com
NEXT_PUBLIC_SALES_EMAIL=sales@liyali.com
NEXT_PUBLIC_PHONE=+1-555-0123

# ----------------------------------------------------------------------------
# Business info
# ----------------------------------------------------------------------------

NEXT_PUBLIC_COMPANY_NAME=Liyali Suite
NEXT_PUBLIC_COMPANY_ADDRESS=123 Business Ave, Tech City, TC 12345
NEXT_PUBLIC_FOUNDED_YEAR=2023


# =============================================================================
# ADMIN CONSOLE  (admin-console/.env)
# =============================================================================

# URL of the Go backend API (used by server components and API routes)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Display name and description shown in the UI
NEXT_PUBLIC_APP_NAME="Liyali Admin Console"
NEXT_PUBLIC_APP_DESCRIPTION="Administrative portal for Liyali Gateway system management"

# Session secret (>= 32 chars) — same rules as the frontend above.
AUTH_SECRET=change-me-to-a-32+-char-random-string
# NEXTAUTH_SECRET=change-me-to-a-32+-char-random-string
