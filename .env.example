# Liyali Gateway - Environment Configuration

# ============================================================
# Server Configuration
# ============================================================

# Server port
PORT=8080

# Environment: development, staging, production
# NOTE: the backend reads APP_ENV (not ENVIRONMENT). Set APP_ENV=production in
# prod — it gates JWT fail-fast, DB SSL=require, and GORM Warn-level logging.
APP_ENV=development

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ============================================================
# Database Configuration
# ============================================================

# PostgreSQL host (use 'postgres' when running in Docker)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=liyali-dev-db

# Production / Railway: the backend AND the migrate binary prefer a single
# connection string. Set this instead of the DB_* parts above. Railway's
# Postgres plugin injects it automatically.
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# SSL Mode: disable, require, verify-ca, verify-full
DB_SSL_MODE=disable

# ============================================================
# Redis Configuration
# ============================================================

# Redis host (use 'redis' when running in Docker)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================
# JWT Configuration
# ============================================================

# JWT secret key — REQUIRED in prod (backend log.Fatal's if empty when
# APP_ENV=production). Use >= 32 random chars.
JWT_SECRET=change-me-to-a-32+-char-random-string

# JWT token expiration (e.g., 24h, 7d)
JWT_EXPIRATION=24h

# ============================================================
# CORS Configuration
# ============================================================

# Comma-separated list of allowed origins.
# NOTE: the backend reads FRONTEND_URL (not CORS_ORIGINS). If unset it defaults
# to http://localhost:3000 and will REJECT the real frontend/admin origins in
# prod — set it to your deployed frontend (and admin) URLs.
FRONTEND_URL=http://localhost:3000,http://localhost:3001

# ============================================================
# Email Configuration (Optional)
# ============================================================

# SMTP host for sending emails
SMTP_HOST=

# SMTP port (usually 587 for TLS or 465 for SSL)
SMTP_PORT=587

# SMTP username
SMTP_USER=

# SMTP password
SMTP_PASSWORD=

# Email from address
EMAIL_FROM=noreply@liyali.com

# ============================================================
# PgAdmin Configuration
# ============================================================

# PgAdmin default email
PGADMIN_EMAIL=admin@liyali.com

# PgAdmin default password
PGADMIN_PASSWORD=change-me

# ============================================================
# Feature Flags
# ============================================================

# Enable/disable features
ENABLE_NOTIFICATIONS=true
ENABLE_AUDIT_LOG=true
ENABLE_BUDGET_CONSTRAINTS=true

# ============================================================
# API Configuration
# ============================================================

# API version
API_VERSION=v1

# Rate limiting: requests per minute
RATE_LIMIT=100

# ============================================================
# Approval Workflow Configuration
# ============================================================

# Approval amount thresholds
LOW_AMOUNT_THRESHOLD=10000
MEDIUM_AMOUNT_THRESHOLD=50000
HIGH_AMOUNT_THRESHOLD=100000

# Budget constraints
VENDOR_SPENDING_LIMIT_PERCENT=30
RESERVE_FUNDS_PERCENT=10

# ============================================================
# File Upload Configuration (if needed)
# ============================================================

# Maximum file upload size (bytes)
MAX_FILE_SIZE=10485760

# Allowed file types
ALLOWED_FILE_TYPES=pdf,xlsx,docx,jpg,png

# ============================================================
# Logging Configuration
# ============================================================

# Log output: stdout, file, both
LOG_OUTPUT=stdout

# Log file path
LOG_FILE=/var/log/liyali-gateway.log

# ============================================================
# Security Configuration
# ============================================================

# Enable HTTPS
ENABLE_HTTPS=false

# TLS certificate path
TLS_CERT_PATH=

# TLS key path
TLS_KEY_PATH=

# ============================================================
# Database Backup Configuration
# ============================================================

# Enable automatic backups
ENABLE_BACKUPS=false

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# Backup retention days
BACKUP_RETENTION_DAYS=30
