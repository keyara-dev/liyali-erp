                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/analytics/requisitions/metrics",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "analytics", "requisitions", "metrics"]
            },
            "description": "Get comprehensive requisition analytics - status counts, rejection rate, rejections over time, rejection reasons, top rejecting approvers"
          },
          "response": []
        },
