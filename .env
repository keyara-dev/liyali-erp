# Liyali Gateway - Environment Configuration

# ============================================================
# Server Configuration
# ============================================================

# Server port
PORT=8080

# Environment: development, staging, production
ENVIRONMENT=development

# Log level: debug, info, warn, error
LOG_LEVEL=debug

# ============================================================
# Database Configuration
# ============================================================

# PostgreSQL host (use 'localhost' for local development)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=00110011
DB_NAME=liyali-dev-db

# SSL Mode: disable, require, verify-ca, verify-full
DB_SSL_MODE=disable

# ============================================================
# Redis Configuration
# ============================================================

# Redis host (use 'localhost' for local development)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================
# JWT Configuration
# ============================================================

# JWT secret key (development key - change in production!)
JWT_SECRET=liyali-gateway-jwt-secret-key-development-2025-secure

# JWT token expiration (e.g., 24h, 7d)
JWT_EXPIRATION=24h

# ============================================================
# CORS Configuration
# ============================================================

# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# ============================================================
# Email Configuration (Optional - disabled for development)
# ============================================================

# SMTP host for sending emails
SMTP_HOST=

# SMTP port (usually 587 for TLS or 465 for SSL)
SMTP_PORT=587

# SMTP username
SMTP_USER=

# SMTP password
SMTP_PASSWORD=

# Email from address
EMAIL_FROM=noreply@liyali.com

# ============================================================
# PgAdmin Configuration
# ============================================================

# PgAdmin default email
PGADMIN_EMAIL=admin@liyali.com

# PgAdmin default password
PGADMIN_PASSWORD=admin123

# ============================================================
# Feature Flags
# ============================================================

# Enable/disable features
ENABLE_NOTIFICATIONS=true
ENABLE_AUDIT_LOG=true
ENABLE_BUDGET_CONSTRAINTS=true

# ============================================================
# API Configuration
# ============================================================

# API version
API_VERSION=v1

# Rate limiting: requests per minute
RATE_LIMIT=100

# ============================================================
# Approval Workflow Configuration
# ============================================================

# Approval amount thresholds (in cents for precision)
LOW_AMOUNT_THRESHOLD=1000000
MEDIUM_AMOUNT_THRESHOLD=5000000
HIGH_AMOUNT_THRESHOLD=10000000

# Budget constraints
VENDOR_SPENDING_LIMIT_PERCENT=30
RESERVE_FUNDS_PERCENT=10

# ============================================================
# File Upload Configuration
# ============================================================

# Maximum file upload size (10MB in bytes)
MAX_FILE_SIZE=10485760

# Allowed file types
ALLOWED_FILE_TYPES=pdf,xlsx,docx,jpg,png

# ============================================================
# Logging Configuration
# ============================================================

# Log output: stdout, file, both
LOG_OUTPUT=stdout

# Log file path
LOG_FILE=/var/log/liyali-gateway.log

# ============================================================
# Security Configuration
# ============================================================

# Enable HTTPS (disabled for local development)
ENABLE_HTTPS=false

# TLS certificate path
TLS_CERT_PATH=

# TLS key path
TLS_KEY_PATH=

# ============================================================
# Database Backup Configuration
# ============================================================

# Enable automatic backups (disabled for development)
ENABLE_BACKUPS=false

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# Backup retention days
BACKUP_RETENTION_DAYS=30