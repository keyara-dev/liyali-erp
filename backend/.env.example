# Database — single connection string (preferred for all environments)
# PaaS platforms (Railway, Fly.io, Supabase, etc.) inject this automatically.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Fallback: individual DB vars (used only when DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_NAME=liyali_gateway
# DB_SSL_MODE=disable

# Skip database validation (useful for slow/remote networks)
SKIP_DB_VALIDATION=false

# Application
APP_PORT=8080
APP_ENV=development
JWT_SECRET=your-secret-key-min-32-chars-change-in-production

# CORS - comma-separated allowed origins
FRONTEND_URL=http://localhost:3000
