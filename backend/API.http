###############################################################################
### ==================== USEFUL NOTES ====================
###############################################################################

# Pre-seeded Test Users (any password works):
# - admin@liyali.com (Role: admin)
# - approver@liyali.com (Role: approver)
# - requester@liyali.com (Role: requester)
# - finance@liyali.com (Role: finance)
# - viewer@liyali.com (Role: viewer)

# Pre-seeded Test Vendors:
# - vendor-001: ABC Supplies Ltd
# - vendor-002: Global Tech Solutions
# - vendor-003: Premium Services Inc

# HTTP Status Codes:
# - 200: Success (GET, PUT, DELETE)
# - 201: Created (POST)
# - 400: Bad Request (Validation error)
# - 401: Unauthorized (No/invalid token)
# - 403: Forbidden (No permission)
# - 404: Not Found (Resource not found)
# - 409: Conflict (Duplicate entry)
# - 422: Unprocessable Entity (Business logic error)
# - 500: Internal Server Error

# Pagination Query Parameters:
# - page: Page number (default: 1)
# - page_size: Items per page (default: 10, max: 100)

# Common Filters:
# - status: draft, pending, approved, rejected
# - department: Department name
# - priority: low, medium, high
# - fiscalYear: Year (e.g., 2025)
# - vendorId: Vendor ID
# - country: Country name
# - active: true/false

###############################################################################
