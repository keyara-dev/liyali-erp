###############################################################################
### ==================== GOODS RECEIVED NOTES - GRN (7 ENDPOINTS) ====================
###############################################################################

### 1. List GRNs
GET http://localhost:8080/api/v1/grns?page=1&page_size=10
Authorization: Bearer <TOKEN>

### 1a. List GRNs with Filters
GET http://localhost:8080/api/v1/grns?page=1&page_size=10&status=draft&poNumber=PO-1703350800-abcd1234
Authorization: Bearer <TOKEN>

### 2. Create GRN
POST http://localhost:8080/api/v1/grns
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "poNumber": "PO-1703350800-abcd1234",
  "items": [
    {
      "name": "Laptop",
      "description": "Laptop Dell XPS 15",
      "quantityOrdered": 2,
      "quantityReceived": 2,
      "variance": 0,
      "condition": "good",
      "serialNumbers": ["DL001", "DL002"]
    },
    {
      "name": "Monitor",
      "description": "Monitor LG 27 inch",
      "quantityOrdered": 2,
      "quantityReceived": 1,
      "variance": -1,
      "condition": "good",
      "serialNumbers": ["LG001"]
    }
  ],
  "receivedBy": "Warehouse Manager John Smith",
  "receivedDate": "2025-12-30T10:00:00Z",
  "inspectionNotes": "All items inspected and verified against PO"
}

### 3. Get GRN Detail
GET http://localhost:8080/api/v1/grns/<ID>
Authorization: Bearer <TOKEN>

### 4. Update GRN with Quality Issues
PUT http://localhost:8080/api/v1/grns/<ID>
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "qualityIssues": [
    {
      "itemDescription": "Monitor LG 27 inch",
      "issueType": "cosmetic_damage",
      "description": "Minor scratch on screen bezel - does not affect functionality",
      "severity": "low",
      "actionRequired": "Accept with note"
    }
  ],
  "inspectionNotes": "Updated with quality issues noted"
}

### 5. Delete GRN (Draft Only)
DELETE http://localhost:8080/api/v1/grns/<ID>
Authorization: Bearer <TOKEN>

### 6. Approve GRN
POST http://localhost:8080/api/v1/grns/<ID>/approve
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "comments": "Goods received, verified, and accepted for inventory",
  "signature": "Warehouse_Manager_20251222"
}

### 7. Reject GRN
POST http://localhost:8080/api/v1/grns/<ID>/reject
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "remarks": "Significant quantity variance detected. Units received: 1, Expected: 2. Please contact vendor regarding missing unit.",
  "signature": "Warehouse_Manager_20251222"
}

