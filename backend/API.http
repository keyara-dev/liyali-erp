###############################################################################
# Liyali Gateway - REST API Endpoints
# Complete API Test Suite - Enhanced Coverage
#
# Usage:
# - Use with VSCode REST Client extension
# - Or import into Postman/Insomnia
# - Replace <TOKEN> with JWT token from login endpoint
# - Replace <ID> with actual resource IDs
#
# Base URL: http://localhost:8080
###############################################################################

### ==================== HEALTH CHECK ====================
### Health Check (No Authentication)
GET http://localhost:8080/health

###############################################################################
### ==================== AUTHENTICATION ====================
###############################################################################

### 1. Register New User
POST http://localhost:8080/api/v1/auth/register
Content-Type: application/json

{
  "email": "newuser@liyali.com",
  "password": "SecurePass123",
  "name": "New User",
  "role": "requester",
  "organizationName": "Test Organization"
}

### 2. Login User
POST http://localhost:8080/api/v1/auth/login
Content-Type: application/json

{
  "email": "admin@liyali.com",
  "password": "admin123"
}

### 3. Verify Token
POST http://localhost:8080/api/v1/auth/verify
Content-Type: application/json

{
  "token": "<TOKEN>"
}

### 4. Refresh Token
POST http://localhost:8080/api/v1/auth/refresh
Content-Type: application/json

{
  "refreshToken": "<REFRESH_TOKEN>"
}

### 5. Get User Profile (Protected)
GET http://localhost:8080/api/v1/auth/profile
Authorization: Bearer <TOKEN>

### 6. Change Password
POST http://localhost:8080/api/v1/auth/change-password
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "currentPassword": "oldPassword123",
  "newPassword": "newSecurePassword456"
}

### 7. Request Password Reset
POST http://localhost:8080/api/v1/auth/password-reset/request
Content-Type: application/json

{
  "email": "user@liyali.com"
}

### 8. Confirm Password Reset
POST http://localhost:8080/api/v1/auth/password-reset/confirm
Content-Type: application/json

{
  "token": "reset-token-here",
  "newPassword": "newSecurePassword789"
}

### 9. Logout Current Session
POST http://localhost:8080/api/v1/auth/logout
Authorization: Bearer <TOKEN>

### 10. Logout All Sessions
POST http://localhost:8080/api/v1/auth/logout-all
Authorization: Bearer <TOKEN>

###############################################################################
### ==================== ORGANIZATIONS ====================
###############################################################################

### 1. List Organizations
GET http://localhost:8080/api/v1/organizations?page=1&limit=20
Authorization: Bearer <TOKEN>

### 2. Create Organization
POST http://localhost:8080/api/v1/organizations
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "name": "New Tech Corp",
  "description": "Technology solutions company"
}

### 3. Get Organization by ID
GET http://localhost:8080/api/v1/organizations/<ID>
Authorization: Bearer <TOKEN>

### 4. Update Organization
PUT http://localhost:8080/api/v1/organizations/<ID>
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "name": "Updated Tech Corp",
  "description": "Updated description"
}

### 5. Switch Organization Context
POST http://localhost:8080/api/v1/organizations/<ID>/switch
Authorization: Bearer <TOKEN>

###############################################################################
### ==================== ORGANIZATION MANAGEMENT ====================
###############################################################################

### 1. List Organization Members
GET http://localhost:8080/api/v1/organization/members?page=1&limit=20&role=user
Authorization: Bearer <TOKEN>

### 2. Add Organization Member
POST http://localhost:8080/api/v1/organization/members
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "email": "newmember@company.com",
  "role": "user",
  "department": "IT",
  "title": "Developer"
}

### 3. Remove Organization Member
DELETE http://localhost:8080/api/v1/organization/members/<USER_ID>
Authorization: Bearer <TOKEN>

### 4. Get Organization Settings
GET http://localhost:8080/api/v1/organization/settings
Authorization: Bearer <TOKEN>

### 5. Update Organization Settings
PUT http://localhost:8080/api/v1/organization/settings
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "approvalThreshold": 5000.00,
  "currency": "USD",
  "fiscalYearStart": "2024-01-01",
  "workflowEnabled": true,
  "notifications": {
    "email": true,
    "sms": false,
    "push": true
  }
}

###############################################################################
### ==================== ROLES & PERMISSIONS ====================
###############################################################################

### 1. List Organization Roles
GET http://localhost:8080/api/v1/organization/roles?active=true
Authorization: Bearer <TOKEN>

### 2. Create Organization Role
POST http://localhost:8080/api/v1/organization/roles
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "name": "Department Manager",
  "description": "Manages department operations and approvals",
  "permissions": ["requisitions.approve", "budgets.view", "users.manage"]
}

### 3. Update Organization Role
PUT http://localhost:8080/api/v1/organization/roles/<ROLE_ID>
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "name": "Senior Manager",
  "description": "Updated role description",
  "permissions": ["requisitions.approve", "budgets.approve", "users.manage"]
}

### 4. Delete Organization Role
DELETE http://localhost:8080/api/v1/organization/roles/<ROLE_ID>
Authorization: Bearer <TOKEN>

### 5. Get Role Permissions
GET http://localhost:8080/api/v1/organization/roles/<ROLE_ID>/permissions
Authorization: Bearer <TOKEN>

### 6. Assign Permission to Role
POST http://localhost:8080/api/v1/organization/roles/<ROLE_ID>/permissions/<PERMISSION_ID>
Authorization: Bearer <TOKEN>

### 7. Remove Permission from Role
DELETE http://localhost:8080/api/v1/organization/roles/<ROLE_ID>/permissions/<PERMISSION_ID>
Authorization: Bearer <TOKEN>

### 8. List Available Permissions
GET http://localhost:8080/api/v1/organization/permissions?category=requisition
Authorization: Bearer <TOKEN>

###############################################################################
### ==================== USERS ====================
###############################################################################

### 1. List Users
GET http://localhost:8080/api/v1/users?page=1&limit=20&department=IT&role=user
Authorization: Bearer <TOKEN>

### 2. Create User
POST http://localhost:8080/api/v1/users
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "email": "newuser@company.com",
  "name": "New Employee",
  "roles": ["user"],
  "department": "Finance",
  "position": "Analyst"
}

### 3. Get User by ID
GET http://localhost:8080/api/v1/users/<USER_ID>
Authorization: Bearer <TOKEN>

### 4. Update User
PUT http://localhost:8080/api/v1/users/<USER_ID>
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "name": "Updated Name",
  "department": "Operations",
  "roles": ["user", "manager"]
}

### 5. Deactivate User
DELETE http://localhost:8080/api/v1/users/<USER_ID>
Authorization: Bearer <TOKEN>

###############################################################################
### ==================== REQUISITIONS (8 ENDPOINTS) ====================
###############################################################################

### 1. List Requisitions
GET http://localhost:8080/api/v1/requisitions?page=1&page_size=10&status=draft
Authorization: Bearer <TOKEN>

### 1a. List Requisitions with Advanced Filters
GET http://localhost:8080/api/v1/requisitions?page=1&page_size=10&status=draft&department=IT&priority=high&minAmount=1000&maxAmount=10000&startDate=2024-01-01&endDate=2024-12-31&sort=createdAt&order=desc
Authorization: Bearer <TOKEN>

### 2. Create Requisition
POST http://localhost:8080/api/v1/requisitions
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "title": "Office Supplies Requisition",
  "description": "Monthly office supplies requisition for Q4 2025 including stationery and printing materials",
  "department": "Administration",
  "priority": "medium",
  "items": [
    {
      "name": "A4 Paper",
      "description": "A4 Paper (500 sheets)",
      "quantity": 10,
      "unitPrice": 5.50,
      "totalPrice": 55.00,
      "category": "Office Supplies",
      "specifications": {
        "brand": "HP",
        "size": "A4",
        "weight": "80gsm"
      }
    },
    {
      "name": "Pens",
      "description": "Pens (Box of 50)",
      "quantity": 5,
      "unitPrice": 12.00,
      "totalPrice": 60.00,
      "category": "Office Supplies"
    }
  ],
  "totalAmount": 115.00,
  "currency": "USD",
  "justification": "Required for daily office operations",
  "expectedDeliveryDate": "2025-01-15T00:00:00Z",
  "budgetCode": "ADMIN-2025-001"
}

### 3. Get Requisition Detail
GET http://localhost:8080/api/v1/requisitions/<ID>
Authorization: Bearer <TOKEN>

### 4. Update Requisition
PUT http://localhost:8080/api/v1/requisitions/<ID>
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "title": "Updated Office Supplies Requisition",
  "totalAmount": 125.00,
  "priority": "high"
}

### 5. Delete Requisition (Draft Only)
DELETE http://localhost:8080/api/v1/requisitions/<ID>
Authorization: Bearer <TOKEN>

### 6. Approve Requisition
POST http://localhost:8080/api/v1/requisitions/<ID>/approve
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "comments": "Approved for procurement",
  "signature": "John_Approver_20251222"
}

### 7. Reject Requisition
POST http://localhost:8080/api/v1/requisitions/<ID>/reject
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "remarks": "Please clarify the budget allocation for this requisition before resubmission",
  "signature": "John_Approver_20251222"
}

### 8. Reassign Requisition
POST http://localhost:8080/api/v1/requisitions/<ID>/reassign
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "newApproverId": "user-approver-001",
  "reason": "Escalating to senior approver for review"
}

###############################################################################
### ==================== BUDGETS (7 ENDPOINTS) ====================
###############################################################################

### 1. List Budgets
GET http://localhost:8080/api/v1/budgets?page=1&page_size=10
Authorization: Bearer <TOKEN>

### 1a. List Budgets with Filters
GET http://localhost:8080/api/v1/budgets?page=1&page_size=10&fiscalYear=2025&department=IT&status=draft
Authorization: Bearer <TOKEN>

### 2. Create Budget
POST http://localhost:8080/api/v1/budgets
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "budgetCode": "BDG-2025-Q4-001",
  "department": "IT",
  "fiscalYear": "2025",
  "totalBudget": 50000.00,
  "allocatedAmount": 20000.00,
  "description": "IT Department budget for Q4 2025",
  "categories": [
    {
      "name": "Hardware",
      "allocation": 30000.00
    },
    {
      "name": "Software",
      "allocation": 15000.00
    },
    {
      "name": "Training",
      "allocation": 5000.00
    }
  ]
}

### 3. Get Budget Detail
GET http://localhost:8080/api/v1/budgets/<ID>
Authorization: Bearer <TOKEN>

### 4. Update Budget
PUT http://localhost:8080/api/v1/budgets/<ID>
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "allocatedAmount": 25000.00,
  "description": "Updated budget allocation"
}

### 5. Delete Budget (Draft Only)
DELETE http://localhost:8080/api/v1/budgets/<ID>
Authorization: Bearer <TOKEN>

### 6. Approve Budget
POST http://localhost:8080/api/v1/budgets/<ID>/approve
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "comments": "Budget approved for fiscal year 2025",
  "signature": "Finance_Officer_20251222"
}

### 7. Reject Budget
POST http://localhost:8080/api/v1/budgets/<ID>/reject
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "remarks": "Budget allocation exceeds departmental limits. Please revise and resubmit.",
  "signature": "Finance_Officer_20251222"
}

###############################################################################
### ==================== PURCHASE ORDERS (7 ENDPOINTS) ====================
###############################################################################

### 1. List Purchase Orders
GET http://localhost:8080/api/v1/purchase-orders?page=1&page_size=10
Authorization: Bearer <TOKEN>

### 1a. List Purchase Orders with Filters
GET http://localhost:8080/api/v1/purchase-orders?page=1&page_size=10&status=draft&vendorId=vendor-001
Authorization: Bearer <TOKEN>

### 2. Create Purchase Order
POST http://localhost:8080/api/v1/purchase-orders
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "vendorId": "vendor-001",
  "items": [
    {
      "name": "Laptop",
      "description": "Laptop Dell XPS 15",
      "quantity": 2,
      "unitPrice": 1200.00,
      "totalPrice": 2400.00,
      "category": "Electronics",
      "specifications": {
        "brand": "Dell",
        "model": "XPS 15",
        "processor": "Intel i7",
        "memory": "16GB",
        "storage": "512GB SSD"
      }
    },
    {
      "name": "Monitor",
      "description": "Monitor LG 27 inch",
      "quantity": 2,
      "unitPrice": 350.00,
      "totalPrice": 700.00,
      "category": "Electronics"
    }
  ],
  "totalAmount": 3100.00,
  "currency": "USD",
  "deliveryDate": "2025-12-31T00:00:00Z",
  "linkedRequisition": "req-uuid-here",
  "terms": "Net 30 days",
  "shippingAddress": "123 Business St, City, State 12345"
}

### 3. Get Purchase Order Detail
GET http://localhost:8080/api/v1/purchase-orders/<ID>
Authorization: Bearer <TOKEN>

### 4. Update Purchase Order
PUT http://localhost:8080/api/v1/purchase-orders/<ID>
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "deliveryDate": "2025-12-29T00:00:00Z",
  "terms": "Net 15 days"
}

### 5. Delete Purchase Order (Draft Only)
DELETE http://localhost:8080/api/v1/purchase-orders/<ID>
Authorization: Bearer <TOKEN>

### 6. Approve Purchase Order
POST http://localhost:8080/api/v1/purchase-orders/<ID>/approve
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "comments": "PO approved for vendor ABC Supplies Ltd",
  "signature": "Approver_Signature_20251222"
}

### 7. Reject Purchase Order
POST http://localhost:8080/api/v1/purchase-orders/<ID>/reject
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "remarks": "Vendor pricing not competitive. Please obtain alternative quotes before resubmission.",
  "signature": "Approver_Signature_20251222"
}

