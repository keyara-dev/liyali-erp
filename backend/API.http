### ==================== WORKFLOWS ====================
###############################################################################

### 1. List Workflows
GET http://localhost:8080/api/v1/workflows?page=1&page_size=10&active=true
Authorization: Bearer <TOKEN>

### 2. Create Workflow
POST http://localhost:8080/api/v1/workflows
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "name": "IT Requisition Approval",
  "description": "Approval workflow for IT department requisitions",
  "documentType": "requisition",
  "steps": [
    {
      "order": 1,
      "name": "Department Manager Review",
      "approverRole": "department_manager",
      "required": true,
      "conditions": {
        "minAmount": 0,
        "maxAmount": 5000
      }
    },
    {
      "order": 2,
      "name": "Finance Approval",
      "approverRole": "finance_manager",
      "required": true,
      "conditions": {
        "minAmount": 1000
      }
    }
  ]
}

### 3. Get Workflow Detail
GET http://localhost:8080/api/v1/workflows/<ID>
Authorization: Bearer <TOKEN>

### 4. Update Workflow
PUT http://localhost:8080/api/v1/workflows/<ID>
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "name": "Updated IT Requisition Approval",
  "description": "Updated workflow description"
}

### 5. Delete Workflow
DELETE http://localhost:8080/api/v1/workflows/<ID>
Authorization: Bearer <TOKEN>

