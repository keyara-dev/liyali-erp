Authorization: Bearer <TOKEN>

### 2. Search Requisitions
GET http://localhost:8080/api/v1/search/requisitions?q=office%20supplies&department=Admin
Authorization: Bearer <TOKEN>

### 3. Search Vendors
GET http://localhost:8080/api/v1/search/vendors?q=tech&country=United%20States
Authorization: Bearer <TOKEN>

### 4. Advanced Search
POST http://localhost:8080/api/v1/search/advanced
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "query": "laptop OR computer",
  "filters": {
    "documentTypes": ["requisition", "purchase_order"],
    "dateRange": {
      "start": "2024-01-01",
      "end": "2024-12-31"
    },
    "amountRange": {
      "min": 1000,
      "max": 10000
    },
    "departments": ["IT", "Finance"]
  },
  "sort": {
    "field": "relevance",
    "order": "desc"
  }
}

