  "comments": "Rejected due to insufficient documentation",
  "signature": "Approver_20251230"
}

### 5. Reassign Task
POST http://localhost:8080/api/v1/approval-tasks/<ID>/reassign
Authorization: Bearer <TOKEN>
Content-Type: application/json

{
  "newApproverId": "user-manager-002",
  "reason": "Original approver unavailable"
}

